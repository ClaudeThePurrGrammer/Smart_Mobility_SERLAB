# IP della macchina host (usato da Metro per pubblicizzarsi su LAN
# e dall'app mobile per raggiungere il backend)
# Trovalo con: ipconfig (Windows) oppure ifconfig (macOS/Linux)
HOST_IP=192.168.x.x

# Backend / sicurezza
JWT_SECRET=cambia_questo_valore_in_produzione

# Credenziali OAuth (opzionali) — necessarie per attivare il login social reale
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# FACEBOOK_APP_ID=xxxxxxxx
# FACEBOOK_APP_SECRET=xxxxxxxx
