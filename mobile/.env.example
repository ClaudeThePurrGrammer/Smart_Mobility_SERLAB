# Copia questo file in "mobile/.env" e incolla i tuoi valori.
# Tutte le variabili EXPO_PUBLIC_* sono incluse nel bundle dell'app (valori PUBBLICI).
# Dopo aver modificato il .env riavvia Metro con: npx expo start -c

# ── Backend (opzionale) ──────────────────────────────────────────────────────
# Di default l'app trova il backend sul PC automaticamente (porta 8000).
# Imposta questo solo se il backend è altrove (es. server remoto).
# EXPO_PUBLIC_API_URL=http://192.168.1.10:8000

# ── Google OAuth (Google Cloud Console → Credenziali → ID client OAuth) ──────
# Crea 3 client ID: iOS, Android (serve SHA-1), Web.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── Facebook OAuth (Meta for Developers → la tua app → Impostazioni → Di base) ─
EXPO_PUBLIC_FACEBOOK_APP_ID=

# Apple non richiede client ID lato app: usa il bundle id (usesAppleSignIn già attivo).
